# Cloudflare Pages response headers

# Web App Manifest — must be application/json for Chrome to recognise it as a PWA manifest
/manifest.json
  Content-Type: application/json
  Cache-Control: no-store

# Service worker — must never be cached so updates roll out immediately
/sw.js
  Content-Type: text/javascript
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate

# Workbox runtime chunks — long-lived, content-hashed filenames
/workbox-*.js
  Cache-Control: public, max-age=31536000, immutable

# HTML — always revalidate so new deploys are picked up
/*.html
  Cache-Control: no-store

/index.html
  Cache-Control: no-store
